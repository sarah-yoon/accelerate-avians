generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Difficulty {
  short
  medium
  long
}

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  username    String   @unique
  displayBird String   @default("robin")
  createdAt   DateTime @default(now())
  scores       Score[]
  matchPlayers MatchPlayer[]

  @@map("users")
}

model Passage {
  id         String     @id @default(cuid())
  text       String
  source     String
  wordCount  Int
  charCount  Int
  difficulty Difficulty
  scores     Score[]
  matches    Match[]

  @@map("passages")
}

model Score {
  id         String   @id @default(cuid())
  userId     String
  passageId  String
  wpm        Int
  accuracy   Float
  ghostData  Json
  createdAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  passage Passage @relation(fields: [passageId], references: [id])

  @@index([passageId, wpm(sort: Desc)])
  @@index([userId])
  @@map("scores")
}

enum MatchStatus {
  waiting
  racing
  completed
  expired
}

enum MatchPlayerStatus {
  racing
  finished
  abandoned
  disconnected
}

model Match {
  id        String      @id @default(cuid())
  roomCode  String      @unique
  passageId String
  status    MatchStatus @default(waiting)
  startedAt DateTime?
  createdAt DateTime    @default(now())

  passage Passage      @relation(fields: [passageId], references: [id])
  players MatchPlayer[]

  @@index([status])
  @@map("matches")
}

model MatchPlayer {
  id         String            @id @default(cuid())
  matchId    String
  userId     String
  wpm        Int?
  accuracy   Float?
  placement  Int?
  ghostData  Json?
  status     MatchPlayerStatus @default(racing)
  startedAt  DateTime          @default(now())
  finishedAt DateTime?

  match Match @relation(fields: [matchId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([matchId, userId])
  @@index([userId])
  @@map("match_players")
}
